# Değiştirebileceğin ölçüler (thresholds)

# shared paket sayısı limiti (shared büyümesini engeller)
MAX_SHARED_PKGS=5

# contracts/v1 içindeki minimum schema sayısı
MIN_V1_SCHEMAS=2

# tenant isolation için "şüpheli query" toleransı (0 öneririm)
MAX_SUSPECT_QUERIES=0

# go mod tidy çalışsın mı? (1/0)
RUN_GO_MOD_TIDY=1
