# === PIX2PI SaaS ENTERPRISE ENV ===

# Environment
APP_NAME=pix2pi-saas
APP_ENV=local   # local|dev|stage|prod
LOG_LEVEL=info

# Ports
SONAR_PORT=9000
IDENTITY_PORT=9001
FINANCE_PORT=9002
GATEWAY_PORT=9003

# Health URLs (runner kontrol eder)
IDENTITY_HEALTH_URL=http://127.0.0.1:${IDENTITY_PORT}/health
FINANCE_HEALTH_URL=http://127.0.0.1:${FINANCE_PORT}/health
GATEWAY_HEALTH_URL=http://127.0.0.1:${GATEWAY_PORT}/health

# Database (Docker Postgres)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=pix2pi_saas
DB_USER=pix2pi_admin
DB_PASSWORD=CHANGE_ME

# Feature flags
FIBER_PREFORK=false
FIBER_DISABLE_STARTUP_MSG=false
