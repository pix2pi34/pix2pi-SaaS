      "display_name",
      "roles",
      "permissions",
      "issued_at",
      "expires_at"
    ],
    "tenant_required_fields": [
      "tenant_id",
      "tenant_uuid",
      "tenant_name",
      "tenant_code",
      "selected_at"
    ],
    "refresh_policy": "REFRESH_BEFORE_EXPIRY",
