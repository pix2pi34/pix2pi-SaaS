{
  "phase": "FAZ_6_R",
  "item": "281",
  "code": "FAZ_6_21_4_2",
  "name": "Abuse / bot tuning",
  "depends_on": "FAZ_6_21_4_1",
  "provider_neutral": true,
  "live_provider_api_mutation_allowed": false,
  "required_controls": [
    "bot_score_policy",
    "suspicious_automation_guard",
    "credential_stuffing_guard",
    "login_rate_anomaly_guard",
    "api_scraping_guard",
    "high_error_rate_guard",
    "bad_user_agent_guard",
    "impossible_path_guard",
    "tenant_abuse_signal_policy",
    "allowlist_policy",
    "false_positive_review_policy",
    "safe_rollout_policy",
    "rollback_policy",
    "evidence_audit_policy"
  ],
  "protected_surfaces": [
    {
      "surface": "auth",
      "routes": [
        "/auth/*",
        "/api/auth/*",
        "/login"
      ],
      "risk": "critical",
      "default_action": "managed_challenge"
    },
    {
      "surface": "api",
      "routes": [
        "/api/*"
      ],
      "risk": "high",
      "default_action": "managed_challenge"
    },
    {
      "surface": "panel",
      "routes": [
        "/panel/*",
        "/admin/*"
      ],
      "risk": "high",
      "default_action": "managed_challenge"
    },
    {
      "surface": "public_web",
      "routes": [
        "/",
        "/faz4r/*",
        "/faz5r/*",
        "/assets/*"
      ],
      "risk": "medium",
      "default_action": "observe"
    },
    {
      "surface": "health",
      "routes": [
        "/health",
        "/api/health",
        "/ready",
        "/live"
      ],
      "risk": "low",
      "default_action": "observe"
    }
  ],
  "signals": [
    {
      "id": "bot-score-low",
      "control": "bot_score_policy",
      "stage": "challenge",
      "action": "managed_challenge",
      "threshold": "low_bot_score"
    },
    {
      "id": "suspicious-automation",
      "control": "suspicious_automation_guard",
      "stage": "challenge",
      "action": "managed_challenge",
      "conditions": [
        "headless_browser_signal",
        "missing_common_headers",
        "excessive_request_velocity"
      ]
    },
    {
      "id": "credential-stuffing",
      "control": "credential_stuffing_guard",
      "stage": "challenge",
      "action": "managed_challenge",
      "routes": [
        "/auth/*",
        "/api/auth/*",
        "/login"
      ]
    },
    {
      "id": "login-rate-anomaly",
      "control": "login_rate_anomaly_guard",
      "stage": "challenge",
      "action": "managed_challenge",
      "window_seconds": 60,
      "max_attempts_per_ip": 20
    },
    {
      "id": "api-scraping",
      "control": "api_scraping_guard",
      "stage": "challenge",
      "action": "managed_challenge",
      "routes": [
        "/api/*"
      ],
      "window_seconds": 60,
      "max_requests_per_ip": 300
    },
    {
      "id": "high-error-rate",
      "control": "high_error_rate_guard",
      "stage": "observe",
      "action": "log",
      "window_seconds": 300,
      "max_4xx_5xx_ratio": 0.65
    },
    {
      "id": "bad-user-agent",
      "control": "bad_user_agent_guard",
      "stage": "enforce",
      "action": "block",
      "patterns": [
        "sqlmap",
        "nikto",
        "masscan",
        "zgrab",
        "acunetix",
        "wpscan"
      ]
    },
    {
      "id": "impossible-path",
      "control": "impossible_path_guard",
      "stage": "enforce",
      "action": "block",
      "paths": [
        "/wp-login.php*",
        "/wp-admin*",
        "/.env*",
        "/phpmyadmin*",
        "/server-status*",
        "/.git/*"
      ]
    },
    {
      "id": "tenant-abuse-signal",
      "control": "tenant_abuse_signal_policy",
      "stage": "observe",
      "action": "log",
      "required_dimensions": [
        "tenant_id",
        "ip",
        "route",
        "request_id",
        "reason"
      ]
    }
  ],
  "allowlist": {
    "control": "allowlist_policy",
    "enabled": true,
    "requires_reason": true,
    "requires_expiry": true,
    "max_expiry_days": 30,
    "owners": [
      "sre",
      "security"
    ]
  },
  "false_positive_review": {
    "control": "false_positive_review_policy",
    "required": true,
    "review_windows": [
      "24h",
      "72h"
    ],
    "requires_sample_requests": true
  },
  "safe_rollout": {
    "control": "safe_rollout_policy",
    "default_stage": "observe",
    "allowed_stages": [
      "observe",
      "challenge",
      "enforce",
      "rollback"
    ],
    "promotion_requires": [
      "false_positive_review",
      "waf_tuning_dependency_pass",
      "rollback_plan_ready",
      "audit_evidence_written"
    ]
  },
  "rollback": {
    "control": "rollback_policy",
    "required": true,
    "strategy": "return_to_previous_stable_abuse_bot_policy",
    "owner": "sre",
    "evidence_required": true
  },
  "audit": {
    "control": "evidence_audit_policy",
    "required": true,
    "evidence_file": "docs/faz6r/evidence/FAZ_6_21_4_2_ABUSE_BOT_TUNING_REAL_IMPLEMENTATION_AUDIT.md"
  }
}
