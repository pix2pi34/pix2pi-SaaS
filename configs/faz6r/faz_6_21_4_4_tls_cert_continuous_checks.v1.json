{
  "phase": "FAZ_6_R",
  "item": "283",
  "code": "FAZ_6_21_4_4",
  "name": "TLS / cert continuous checks",
  "depends_on": [
    "FAZ_6_21_4_3"
  ],
  "provider_neutral": true,
  "live_certificate_mutation_allowed": false,
  "required_controls": [
    "edge_rule_review_dependency_gate",
    "tls_domain_inventory",
    "certificate_expiry_check_policy",
    "https_enforcement_policy",
    "hsts_policy",
    "tls_min_version_policy",
    "certificate_chain_validation_policy",
    "canonical_host_tls_policy",
    "api_domain_tls_policy",
    "auth_domain_tls_policy",
    "panel_domain_tls_policy",
    "alert_threshold_policy",
    "scheduled_check_policy",
    "rollback_policy",
    "evidence_audit_policy"
  ],
  "domains": [
    {
      "host": "pix2pi.com.tr",
      "class": "apex",
      "https_required": true,
      "hsts_required": true,
      "min_tls_version": "TLSv1.2"
    },
    {
      "host": "www.pix2pi.com.tr",
      "class": "canonical_public_web",
      "https_required": true,
      "hsts_required": true,
      "min_tls_version": "TLSv1.2"
    },
    {
      "host": "api.pix2pi.com.tr",
      "class": "api",
      "https_required": true,
      "hsts_required": true,
      "min_tls_version": "TLSv1.2"
    },
    {
      "host": "auth.pix2pi.com.tr",
      "class": "auth",
      "https_required": true,
      "hsts_required": true,
      "min_tls_version": "TLSv1.2"
    },
    {
      "host": "panel.pix2pi.com.tr",
      "class": "panel",
      "https_required": true,
      "hsts_required": true,
      "min_tls_version": "TLSv1.2"
    },
    {
      "host": "pos.pix2pi.com.tr",
      "class": "pos",
      "https_required": true,
      "hsts_required": true,
      "min_tls_version": "TLSv1.2"
    }
  ],
  "certificate_expiry_check_policy": {
    "enabled": true,
    "warning_days": 30,
    "critical_days": 14,
    "blocker_days": 7,
    "required_output_fields": [
      "host",
      "issuer",
      "not_before",
      "not_after",
      "days_remaining",
      "status"
    ]
  },
  "https_enforcement_policy": {
    "enabled": true,
    "http_to_https_redirect_required": true,
    "mixed_content_review_required": true
  },
  "hsts_policy": {
    "enabled": true,
    "required_header": "Strict-Transport-Security",
    "minimum_max_age_seconds": 15552000,
    "include_subdomains_review_required": true,
    "preload_review_required": true
  },
  "tls_min_version_policy": {
    "enabled": true,
    "minimum_allowed": "TLSv1.2",
    "preferred": "TLSv1.3"
  },
  "certificate_chain_validation_policy": {
    "enabled": true,
    "verify_chain": true,
    "verify_hostname": true,
    "verify_not_expired": true
  },
  "scheduled_check_policy": {
    "enabled": true,
    "mode": "review_ready",
    "suggested_frequency": "daily",
    "suggested_runtime": "03:40",
    "live_cron_mutation_allowed": false
  },
  "alert_threshold_policy": {
    "enabled": true,
    "warning_days": 30,
    "critical_days": 14,
    "blocker_days": 7,
    "alert_targets": [
      "sre",
      "security",
      "ops"
    ]
  },
  "rollback": {
    "control": "rollback_policy",
    "required": true,
    "strategy": "return_to_previous_stable_tls_edge_policy",
    "owner": "sre",
    "evidence_required": true
  },
  "audit": {
    "control": "evidence_audit_policy",
    "required": true,
    "evidence_file": "docs/faz6r/evidence/FAZ_6_21_4_4_TLS_CERT_CONTINUOUS_CHECKS_REAL_IMPLEMENTATION_AUDIT.md"
  }
}
