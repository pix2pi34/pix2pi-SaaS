{
  "step": "FAZ 7-R / 349",
  "name": "Kullanıcı şifre / giriş akışı gerçek V2",
  "status": "real_implementation",
  "routes": {
    "screen": "/password-login/",
    "runtime": "/password-login/password-login-runtime.js",
    "tenantSelectionHandoff": "/tenant-select/"
  },
  "passwordPolicy": {
    "minLength": 10,
    "requireUpper": true,
    "requireLower": true,
    "requireDigit": true,
    "requireSymbol": true
  },
  "sessionPolicy": {
    "accessTokenMinutes": 15,
    "idleTimeoutMinutes": 30,
    "absoluteTimeoutHours": 12
  },
  "realFlow": {
    "passwordSetup": true,
    "passwordReset": true,
    "loginAfterPassword": true,
    "tenantSelectionAfterLogin": true,
    "sessionValidation": true,
    "auditEvent": true
  },
  "completionPolicy": {
    "screenOnlyImplementationAllowed": false,
    "disabledRuntimeAllowed": false,
    "incompletePassAllowed": false,
    "realRuntimeRequired": true,
    "goTestRequired": true,
    "smokeRequired": true
  }
}
