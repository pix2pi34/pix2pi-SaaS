      "tenant_created_at",
      "tenant_closed_at",
      "freeze_reason"
    ],
    "sales_crm_data": [
      "lead_state",
      "proposal_state",
      "won_reason",
      "lost_reason",
      "sales_channel"
    ],
    "support_signal_data": [
      "incident_class",
      "support_level",
      "open_ticket_count",
      "p0_p1_incident_count"
    ]
  },
  "dashboard_readiness": {
    "revenue_overview_required": true,
    "package_distribution_required": true,
    "collection_health_required": true,
    "churn_view_required": true,
    "sales_funnel_required": true,
