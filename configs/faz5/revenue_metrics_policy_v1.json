{
  "catalog_code": "pix2pi_revenue_metrics_policy_v1",
  "phase": "FAZ_5",
  "step": "5-9",
  "depends_on": [
    "pix2pi_packages_pricing_v1",
    "pix2pi_entitlement_matrix_v1",
    "pix2pi_subscription_billing_policy_v1",
    "pix2pi_tenant_lifecycle_policy_v1",
    "pix2pi_sales_demo_crm_policy_v1"
  ],
  "currency": "TRY",
  "metric_catalog": [
    {
      "code": "mrr",
      "name": "Monthly Recurring Revenue",
      "name_tr": "Aylık tekrar eden gelir",
      "category": "revenue"
    },
    {
      "code": "arr",
      "name": "Annual Recurring Revenue",
      "name_tr": "Yıllık tekrar eden gelir",
      "category": "revenue"
    },
    {
      "code": "logo_churn",
      "name": "Logo Churn",
      "name_tr": "Müşteri kayıp oranı",
      "category": "churn"
    },
    {
      "code": "revenue_churn",
      "name": "Revenue Churn",
      "name_tr": "Gelir kayıp oranı",
      "category": "churn"
    },
    {
      "code": "expansion_revenue",
      "name": "Expansion Revenue",
      "name_tr": "Mevcut müşteriden ek gelir",
      "category": "revenue"
    },
    {
      "code": "contraction_revenue",
      "name": "Contraction Revenue",
      "name_tr": "Mevcut müşteride gelir azalması",
      "category": "revenue"
    },
    {
      "code": "net_revenue_retention",
      "name": "Net Revenue Retention",
      "name_tr": "Net gelir koruma oranı",
      "category": "retention"
    },
    {
      "code": "gross_revenue_retention",
      "name": "Gross Revenue Retention",
      "name_tr": "Brüt gelir koruma oranı",
      "category": "retention"
    },
    {
      "code": "average_revenue_per_tenant",
      "name": "Average Revenue Per Tenant",
      "name_tr": "Tenant başına ortalama gelir",
      "category": "revenue"
    }
  ],
  "formula_catalog": {
    "mrr": "sum(active_monthly_recurring_revenue)",
    "arr": "mrr * 12",
    "logo_churn": "cancelled_customers / starting_customers",
    "revenue_churn": "lost_mrr / starting_mrr",
    "expansion_revenue": "upgrade_revenue + add_on_revenue + extra_user_revenue + extra_branch_revenue + extra_company_revenue",
    "contraction_revenue": "downgrade_loss + removed_add_on_loss + reduced_usage_loss",
    "net_revenue_retention": "(starting_mrr + expansion_revenue - contraction_revenue - churned_mrr) / starting_mrr",
    "gross_revenue_retention": "(starting_mrr - contraction_revenue - churned_mrr) / starting_mrr",
    "average_revenue_per_tenant": "active_mrr / active_paid_tenant_count"
  },
  "package_metrics": {
    "demo_count": true,
    "starter_customer_count": true,
    "pro_customer_count": true,
    "enterprise_customer_count": true,
    "accountant_workspace_count": true,
    "accountant_company_revenue": true,
    "package_distribution": true
  },
  "collection_metrics": {
    "successful_payment_rate": true,
    "failed_payment_rate": true,
    "past_due_customer_count": true,
    "suspended_tenant_count": true,
    "cancelled_subscription_rate": true,
    "average_revenue_per_tenant": true
  },
  "data_source_mapping": {
