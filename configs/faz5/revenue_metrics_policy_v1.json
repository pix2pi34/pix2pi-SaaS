    "payment_failure_alert": true,
    "past_due_spike_alert": true,
    "churn_spike_alert": true,
    "support_p1_spike_alert": true
  },
  "excluded_from_mrr": [
    "demo",
    "trial_without_payment",
    "cancelled",
    "suspended_without_collectible_revenue"
  ],
  "included_in_mrr": [
