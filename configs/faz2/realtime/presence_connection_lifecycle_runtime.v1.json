  "presence_statuses": [
    "CONNECTED",
    "DISCONNECTED"
  ],
  "transports": [
    "websocket",
    "sse"
  ],
  "lifecycle_events": [
    "connect",
    "heartbeat",
    "disconnect"
  ],
  "bridges": {
    "websocket": true,
    "sse": true
  },
  "audit_fields": [
    "connection_id",
    "tenant_id",
    "channel",
    "user_id",
    "transport",
    "status",
    "connected_at",
    "last_seen_at",
    "disconnected_at"
  ],
  "production_live_policy": "runtime_ready_but_distributed_presence_store_in_later_phase"
}
