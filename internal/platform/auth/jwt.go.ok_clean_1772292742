// L23_SECRET_TRACE
func l23SecretTrace(tag string, sec string) {
	if sec == "" {
		fmt.Printf("L23_SECRET_TRACE %s: EMPTY\n", tag)
		return
	}
	a := sec
	head := a
	tail := a
	if len(a) > 2 {
		head = a[:2]
		tail = a[len(a)-2:]
	}
	fmt.Printf("L23_SECRET_TRACE %s: len=%d head=%s tail=%s\n", tag, len(a), head, tail)
}

