# =============================================================
# PIX2PI SaaS — Ortam Değişkenleri Şablonu
# KULLANIM: Bu dosyayı kopyalayın: cp .env.example .env
# UYARI:    .env ASLA git'e commit edilmez!
# =============================================================

# Uygulama
APP_ENV=development         # development | staging | production
APP_NAME=pix2pi

# JWT Güvenlik (minimum 32 karakter — openssl rand -hex 32)
JWT_SECRET=BURAYA_EN_AZ_32_KARAKTER_RANDOM_DEGER_YAZIN

# PostgreSQL — Write (Primary)
DB_WRITE_DSN=postgres://KULLANICI:SIFRE@HOST:5433/DBNAME?sslmode=require

# PostgreSQL — Read (Replica veya Primary ile aynı)
DB_READ_DSN=postgres://KULLANICI:SIFRE@HOST:5433/DBNAME?sslmode=require

# PostgreSQL — Genel (legacy)
DB_DSN=postgres://KULLANICI:SIFRE@HOST:5433/DBNAME?sslmode=require

# Ayrı bileşenler (bazı eski servisler için)
DB_HOST=localhost
DB_PORT=5433
DB_USER=KULLANICI
DB_PASSWORD=SIFRE
DB_NAME=pix2pi

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# NATS
NATS_URL=nats://localhost:4222

# Dev Token (yalnızca development, boş bırakırsanız endpoint çalışmaz)
# DEV_TOKEN_PORT=9011
# DEV_TOKEN_BIND=127.0.0.1
# DEV_TOKEN_VALUE=GECICI_GELISTIRME_TOKEN

# Observability
# GRAFANA_ADMIN_PASSWORD=
# PROMETHEUS_RETENTION=15d
