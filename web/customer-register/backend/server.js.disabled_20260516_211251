'use strict';

const http = require('http');
const https = require('https');
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');

const PORT = Number(process.env.CUSTOMER_REGISTER_API_PORT || 9024);
const DATA_DIR = process.env.CUSTOMER_REGISTER_DATA_DIR || path.join(__dirname, '..', 'data');
const JSONL_FILE = path.join(DATA_DIR, 'applications.jsonl');
const JSON_DIR = path.join(DATA_DIR, 'applications');
const RESEND_API_KEY = process.env.RESEND_API_KEY || '';
const ADMIN_EMAIL = process.env.PIX2PI_ADMIN_EMAIL || 'surucukursu58@gmail.com';
const FROM_EMAIL = process.env.PIX2PI_RESEND_FROM || 'Pix2pi <onboarding@pix2pi.com.tr>';
const PANEL_HOST = process.env.CUSTOMER_REGISTER_PANEL_HOST || 'panel.pix2pi.com.tr';

fs.mkdirSync(DATA_DIR, { recursive: true });
fs.mkdirSync(JSON_DIR, { recursive: true });

function sendJson(res, status, payload) {
  const body = JSON.stringify(payload);
  res.writeHead(status, {
    'Content-Type': 'application/json; charset=utf-8',
    'Content-Length': Buffer.byteLength(body),
    'Cache-Control': 'no-store',
    'X-Pix2pi-Marker': 'CUSTOMER_REGISTER_BACKEND_MARKER'
  });
  res.end(body);
}

function readBody(req) {
  return new Promise((resolve, reject) => {
    let data = '';
    req.on('data', chunk => {
      data += chunk;
      if (data.length > 1024 * 1024) {
        reject(new Error('Body too large'));
        req.destroy();
      }
    });
    req.on('end', () => resolve(data));
    req.on('error', reject);
  });
}

function isEmail(v) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(v || '').trim());
}

function cleanString(v) {
  return String(v || '').trim();
}

function validateApplication(input) {
  const errors = [];

  const payload = {
    companyTitle: cleanString(input.companyTitle || input.firmaUnvani),
    taxOrIdentityNo: cleanString(input.taxOrIdentityNo || input.vergiNoTckn),
    authorizedFullName: cleanString(input.authorizedFullName || input.yetkiliAdSoyad),
    authorizedEmail: cleanString(input.authorizedEmail || input.yetkiliEposta),
    phone: cleanString(input.phone || input.telefon),
    sector: cleanString(input.sector || input.sektor),
    branchCount: Number(input.branchCount || input.subeSayisi || 0),
    modules: Array.isArray(input.modules || input.moduller) ? (input.modules || input.moduller).map(cleanString).filter(Boolean) : []
  };

  if (payload.companyTitle.length < 2) errors.push('Firma ünvanı zorunlu');
  if (!/^[0-9]{10,11}$/.test(payload.taxOrIdentityNo)) errors.push('Vergi no / TCKN 10 veya 11 haneli olmalı');
  if (payload.authorizedFullName.length < 3) errors.push('Yetkili ad soyad zorunlu');
  if (!isEmail(payload.authorizedEmail)) errors.push('Yetkili e-posta geçerli olmalı');
  if (payload.phone.length < 7) errors.push('Telefon zorunlu');
  if (payload.sector.length < 2) errors.push('Sektör zorunlu');
  if (!Number.isInteger(payload.branchCount) || payload.branchCount < 1) errors.push('Şube sayısı en az 1 olmalı');
  if (payload.modules.length < 1) errors.push('En az bir modül seçilmeli');

  return { payload, errors };
}

function createApplication(payload) {
  const now = new Date();
  const id = `CR-${now.toISOString().slice(0,10).replace(/-/g, '')}-${crypto.randomBytes(4).toString('hex').toUpperCase()}`;

  return {
    id,
    status: 'PENDING',
    tenantProvisioned: false,
    adminApprovalRequired: true,
    source: 'customer-register-live',
    submittedAt: now.toISOString(),
    companyTitle: payload.companyTitle,
    taxOrIdentityNo: payload.taxOrIdentityNo,
    authorizedFullName: payload.authorizedFullName,
    authorizedEmail: payload.authorizedEmail,
    phone: payload.phone,
    sector: payload.sector,
    branchCount: payload.branchCount,
    modules: payload.modules
  };
}

function persistApplication(application) {
  fs.appendFileSync(JSONL_FILE, JSON.stringify(application) + '\n', 'utf8');
  fs.writeFileSync(path.join(JSON_DIR, `${application.id}.json`), JSON.stringify(application, null, 2), 'utf8');
}

function resendEmail({ to, subject, html, text }) {
  return new Promise((resolve, reject) => {
    if (!RESEND_API_KEY) {
      reject(new Error('RESEND_API_KEY missing'));
      return;
    }

    const payload = JSON.stringify({
      from: FROM_EMAIL,
      to: [to],
      subject,
      html,
      text
    });

    const req = https.request({
      hostname: 'api.resend.com',
      path: '/emails',
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${RESEND_API_KEY}`,
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(payload)
      },
      timeout: 20000
    }, res => {
      let data = '';
      res.on('data', chunk => { data += chunk; });
      res.on('end', () => {
        let parsed = {};
        try { parsed = JSON.parse(data || '{}'); } catch (_) { parsed = { raw: data }; }
        if (res.statusCode >= 200 && res.statusCode < 300) {
          resolve({ ok: true, statusCode: res.statusCode, providerId: parsed.id || null });
        } else {
          reject(new Error(`Resend HTTP ${res.statusCode}: ${data}`));
        }
      });
    });

    req.on('timeout', () => {
      req.destroy(new Error('Resend timeout'));
    });
    req.on('error', reject);
    req.write(payload);
    req.end();
  });
}

function applicantHtml(app) {
  return `
  <div style="font-family:Arial,sans-serif;line-height:1.5">
    <h2>Pix2pi işletme başvurunuz alındı</h2>
    <p>Merhaba ${escapeHtml(app.authorizedFullName)},</p>
    <p><b>${escapeHtml(app.companyTitle)}</b> için işletme kayıt başvurunuz alındı.</p>
    <p>Başvuru numarası: <b>${app.id}</b></p>
    <p>Durum: <b>${app.status}</b></p>
    <p>Tenant hemen açılmadı. Admin onayı sonrası bilgilendirme yapılacaktır.</p>
    <p>Panel: https://${PANEL_HOST}/customer-login/react/</p>
  </div>`;
}

function adminHtml(app) {
  return `
  <div style="font-family:Arial,sans-serif;line-height:1.5">
    <h2>Yeni Pix2pi işletme kayıt başvurusu</h2>
    <p>Başvuru numarası: <b>${app.id}</b></p>
    <ul>
      <li>Firma: ${escapeHtml(app.companyTitle)}</li>
      <li>Vergi no / TCKN: ${escapeHtml(app.taxOrIdentityNo)}</li>
      <li>Yetkili: ${escapeHtml(app.authorizedFullName)}</li>
      <li>E-posta: ${escapeHtml(app.authorizedEmail)}</li>
      <li>Telefon: ${escapeHtml(app.phone)}</li>
      <li>Sektör: ${escapeHtml(app.sector)}</li>
      <li>Şube sayısı: ${app.branchCount}</li>
      <li>Modüller: ${escapeHtml(app.modules.join(', '))}</li>
      <li>Durum: ${app.status}</li>
      <li>Tenant açıldı mı: ${app.tenantProvisioned ? 'Evet' : 'Hayır'}</li>
    </ul>
    <p>Admin onayı bekleniyor.</p>
  </div>`;
}

function escapeHtml(s) {
  return String(s)
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}

async function handleCreateApplication(req, res) {
  let raw = '';
  try {
    raw = await readBody(req);
  } catch (err) {
    sendJson(res, 413, { ok: false, error: err.message });
    return;
  }

  let input = {};
  try {
    input = JSON.parse(raw || '{}');
  } catch (_) {
    sendJson(res, 400, { ok: false, error: 'JSON body geçersiz' });
    return;
  }

  const { payload, errors } = validateApplication(input);
  if (errors.length) {
    sendJson(res, 422, { ok: false, errors });
    return;
  }

  const application = createApplication(payload);

  let applicantMail = null;
  let adminMail = null;

  try {
    applicantMail = await resendEmail({
      to: application.authorizedEmail,
      subject: `Pix2pi başvurunuz alındı - ${application.id}`,
      html: applicantHtml(application),
      text: `Pix2pi başvurunuz alındı. Başvuru: ${application.id}. Durum: ${application.status}. Tenant admin onayı bekliyor.`
    });

    adminMail = await resendEmail({
      to: ADMIN_EMAIL,
      subject: `Yeni Pix2pi işletme başvurusu - ${application.id}`,
      html: adminHtml(application),
      text: `Yeni başvuru: ${application.id}. Firma: ${application.companyTitle}. Durum: ${application.status}. Tenant açılmadı, admin onayı bekliyor.`
    });

    persistApplication(application);

    sendJson(res, 201, {
      ok: true,
      application: {
        id: application.id,
        status: application.status,
        tenantProvisioned: application.tenantProvisioned,
        adminApprovalRequired: application.adminApprovalRequired
      },
      mails: {
        applicant: applicantMail,
        admin: adminMail
      },
      marker: 'CUSTOMER_REGISTER_APPLICATION_CREATED'
    });
  } catch (err) {
    sendJson(res, 502, {
      ok: false,
      error: 'Başvuru maili gönderilemedi, kayıt tamamlanmadı',
      detail: err.message,
      marker: 'CUSTOMER_REGISTER_MAIL_FAILED'
    });
  }
}

const server = http.createServer(async (req, res) => {
  const url = new URL(req.url, `http://${req.headers.host || 'localhost'}`);

  if (req.method === 'OPTIONS') {
    res.writeHead(204, {
      'Access-Control-Allow-Origin': '*',
      'Access-Control-Allow-Methods': 'GET,POST,OPTIONS',
      'Access-Control-Allow-Headers': 'Content-Type'
    });
    res.end();
    return;
  }

  if (req.method === 'GET' && url.pathname === '/health') {
    sendJson(res, 200, {
      ok: true,
      service: 'pix2pi-customer-register',
      status: 'healthy',
      marker: 'CUSTOMER_REGISTER_BACKEND_MARKER',
      dataDir: DATA_DIR,
      mailReady: Boolean(RESEND_API_KEY),
      tenantAutoProvision: false
    });
    return;
  }

  if (req.method === 'GET' && url.pathname === '/api/customer-register/health') {
    sendJson(res, 200, {
      ok: true,
      service: 'pix2pi-customer-register',
      status: 'healthy',
      marker: 'CUSTOMER_REGISTER_API_HEALTH_MARKER',
      tenantAutoProvision: false
    });
    return;
  }

  if (req.method === 'POST' && url.pathname === '/api/customer-register/applications') {
    await handleCreateApplication(req, res);
    return;
  }

  sendJson(res, 404, { ok: false, error: 'not found' });
});

server.listen(PORT, '127.0.0.1', () => {
  console.log(`pix2pi customer register backend listening on 127.0.0.1:${PORT}`);
});
