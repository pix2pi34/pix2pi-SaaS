GRAFANA_ALERT_ROUTE=ops-grafana-route
EMAIL_CHANNEL=ops@pix2pi.com.tr
CHAT_CHANNEL=#pix2pi-alerts

SEVERITY_WARN_ROUTE=warning-oncall
SEVERITY_CRIT_ROUTE=critical-oncall

ACK_TIMEOUT_MINUTES=15
SILENCE_WINDOW_MINUTES=30

ESCALATION_LEVEL1_MINUTES=10
ESCALATION_LEVEL2_MINUTES=20
ESCALATION_LEVEL3_MINUTES=30

THRESHOLD_SIMULATION_ENABLED=true
FALSE_POSITIVE_MAX_PERCENT=5
FALSE_NEGATIVE_MAX_PERCENT=2
DRY_RUN_MODE=true
CORRELATION_VALIDATION_REQUIRED=true
EARLY_WARNING_SUITE=enabled
