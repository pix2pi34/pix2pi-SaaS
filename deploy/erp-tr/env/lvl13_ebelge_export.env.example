EBELGE_EFATURA_ENABLED=true
EBELGE_EARSIV_ENABLED=true
EBELGE_EADISYON_ENABLED=true
EBELGE_STATUS_SYNC_MODE=bidirectional
EBELGE_RETRY_MAX=5
