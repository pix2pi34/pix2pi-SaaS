server {
    location = / {
        add_header X-Pix2pi-Public-Root "PIX2PI_PUBLIC_HOME_ALIAS_ROOT_MARKER" always;
        default_type text/html;
        alias /var/www/pix2pi/live/pix2pi_home.html;
    }

    location = /pix2pi_home.html {
        add_header X-Pix2pi-Public-Home "PIX2PI_PUBLIC_HOME_ALIAS_FILE_MARKER" always;
        default_type text/html;
        alias /var/www/pix2pi/live/pix2pi_home.html;
    }




    listen 80;
    server_name pix2pi.com.tr www.pix2pi.com.tr;
    include /etc/nginx/snippets/pix2pi_home_image_assets_locations.conf;
    include /etc/nginx/snippets/pix2pi_public_home_named_pages.conf;
    location /faz4d/ {
        return 301 https://$host$request_uri;
    }

    location / {
        return 301 https://$host$request_uri;
    }

}



