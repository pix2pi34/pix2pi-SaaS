    server_name panel.pix2pi.com.tr;
    include /etc/nginx/snippets/pix2pi_customer_login_activation_locations.conf;
    include /etc/nginx/snippets/pix2pi_customer_register_submit_locations.conf;
    include /etc/nginx/snippets/pix2pi_customer_login_application_status_locations.conf;
    include /etc/nginx/snippets/pix2pi_owner_register_approvals_locations.conf;
    root /var/www/pix2pi/panel;
    index index.html;

